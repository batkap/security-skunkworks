{
  "allowed_write_scopes": [
    ".security-skunkworks"
  ],
  "branch": "",
  "coverage_status": "full",
  "created_at": "<TIMESTAMP>",
  "effective_config": {
    "compliance_frameworks": [
      "owasp",
      "asvs",
      "cwe"
    ],
    "default_mode": "read-only",
    "docs_destination": "docs/security",
    "exclude_paths": [
      ".git",
      "node_modules",
      ".venv",
      "venv",
      ".fvm",
      "__pycache__",
      "dist",
      "build"
    ],
    "gate_thresholds": {
      "default": "gated"
    },
    "include_paths": [],
    "primary_frameworks": [],
    "required_scanners": {
      "containers": [
        "trivy"
      ],
      "dart": [
        "semgrep",
        "gitleaks",
        "osv-scanner"
      ],
      "javascript": [
        "semgrep",
        "gitleaks",
        "npm-audit"
      ],
      "python": [
        "semgrep",
        "gitleaks",
        "pip-audit"
      ],
      "typescript": [
        "semgrep",
        "gitleaks",
        "npm-audit"
      ]
    },
    "sensitive_paths": []
  },
  "excluded_host_paths": [
    "android",
    "ios"
  ],
  "mode": "read-only",
  "repo_path": "<REPO_PATH>",
  "run_id": "flutter-golden",
  "scanners": {
    "gitleaks": {
      "available": true,
      "command": [
        "gitleaks",
        "detect",
        "--no-git",
        "--source",
        "<REPO_PATH>",
        "--report-format",
        "json",
        "--report-path",
        "<REPO_PATH>/.security-skunkworks/runs/flutter-golden/findings/scanners/gitleaks.json"
      ],
      "coverage_gap": "",
      "error": "",
      "executed": true,
      "findings": [],
      "name": "gitleaks",
      "output_path": "<REPO_PATH>/.security-skunkworks/runs/flutter-golden/findings/scanners/gitleaks.json",
      "required": true,
      "success": true
    },
    "osv-scanner": {
      "available": true,
      "command": [
        "osv-scanner",
        "scan",
        "source",
        "--format",
        "json",
        "--lockfile=<REPO_PATH>/pubspec.lock",
        "--lockfile=<REPO_PATH>/packages/cache/pubspec.lock"
      ],
      "coverage_gap": "",
      "error": "",
      "executed": true,
      "findings": [],
      "name": "osv-scanner",
      "output_path": "<REPO_PATH>/.security-skunkworks/runs/flutter-golden/findings/scanners/osv-scanner.json",
      "required": true,
      "success": true
    },
    "pnpm-audit": {
      "available": true,
      "command": [
        "pnpm",
        "audit",
        "--json"
      ],
      "coverage_gap": "",
      "error": "",
      "executed": true,
      "findings": [],
      "name": "pnpm-audit",
      "output_path": "<REPO_PATH>/.security-skunkworks/runs/flutter-golden/findings/scanners/pnpm-audit.json",
      "required": true,
      "success": true
    },
    "semgrep": {
      "available": true,
      "command": [
        "semgrep",
        "scan",
        "--config",
        "auto",
        "--json",
        "--output",
        "<REPO_PATH>/.security-skunkworks/runs/flutter-golden/findings/scanners/semgrep.json",
        "--exclude",
        ".git",
        "--exclude",
        "node_modules",
        "--exclude",
        ".venv",
        "--exclude",
        "venv",
        "--exclude",
        ".fvm",
        "--exclude",
        "__pycache__",
        "--exclude",
        "dist",
        "--exclude",
        "build",
        "--exclude",
        "android",
        "--exclude",
        "ios",
        "--exclude",
        ".security-skunkworks",
        "--exclude",
        "ios/Flutter/ephemeral",
        "--exclude",
        "**/GeneratedPluginRegistrant.java",
        "--exclude",
        "**/GeneratedPluginRegistrant.m",
        "--exclude",
        "**/GeneratedPluginRegistrant.h",
        "<REPO_PATH>"
      ],
      "coverage_gap": "",
      "error": "",
      "executed": true,
      "findings": [],
      "name": "semgrep",
      "output_path": "<REPO_PATH>/.security-skunkworks/runs/flutter-golden/findings/scanners/semgrep.json",
      "required": true,
      "success": true
    }
  },
  "status": "report_ready",
  "support_reason": "Trusted boundary covers: ., functions, packages/cache. Standard native host paths are excluded from trusted verification: android, ios.",
  "supported_roots": [
    ".",
    "functions",
    "packages/cache"
  ],
  "unsupported_items": []
}
